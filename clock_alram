import tkinter as tk
from time import strftime
import winsound  # For Windows sound

root = tk.Tk()
root.title("Alarm Clock")

# Function to update time
def time():
    current_time = strftime('%H:%M:%S')
    clock_label.config(text=current_time)

    # Check alarm
    if current_time == alarm_time.get():
        winsound.Beep(1000, 1000)  # Beep sound

    clock_label.after(1000, time)

# UI Elements
clock_label = tk.Label(root, font=('calibri', 40, 'bold'),
                       background='black', foreground='white')
clock_label.pack(pady=20)

tk.Label(root, text="Set Alarm (HH:MM:SS)", font=('calibri', 15)).pack()

alarm_time = tk.StringVar()
entry = tk.Entry(root, textvariable=alarm_time, font=('calibri', 15))
entry.pack(pady=10)

time()
root.mainloop()